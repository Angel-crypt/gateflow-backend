{
  "info": {
    "name": "GateFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set('access_token', res.access);",
                  "pm.environment.set('refresh_token', res.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set('access_token', res.access);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/refresh/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Me (Perfil)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/change-password/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"admin1234\",\n  \"new_password\": \"nueva_segura123\",\n  \"confirm_password\": \"nueva_segura123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/",
              "host": ["{{base_url}}"],
              "path": ["api", "users", ""],
              "query": [
                { "key": "role", "value": "guard", "disabled": true },
                { "key": "is_active", "value": "true", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "page_size", "value": "20", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Guard",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/users/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guardia01@parque.com\",\n  \"password\": \"temp1234\",\n  \"first_name\": \"Luis\",\n  \"last_name\": \"Martínez\",\n  \"role\": \"guard\"\n}"
            }
          }
        },
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/users/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"inquilino@abc.com\",\n  \"password\": \"temp1234\",\n  \"first_name\": \"Carlos\",\n  \"last_name\": \"López\",\n  \"role\": \"tenant\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Destinations",
      "item": [
        {
          "name": "List Destinations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/destinations/",
              "host": ["{{base_url}}"],
              "path": ["api", "destinations", ""],
              "query": [
                { "key": "page", "value": "1", "disabled": true },
                { "key": "page_size", "value": "20", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Destination",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.environment.set('destination_id', res.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/destinations/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Empresa Nueva\",\n  \"type\": \"company\",\n  \"responsible\": null\n}"
            }
          }
        },
        {
          "name": "Get Destination",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/destinations/{{destination_id}}/"
          }
        },
        {
          "name": "Update Destination",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/destinations/{{destination_id}}/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nombre Actualizado\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Delete Destination",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/destinations/{{destination_id}}/"
          }
        }
      ]
    }
  ]
}
