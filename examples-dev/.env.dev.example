# Clave secreta para desarrollo (no usar en producción)
SECRET_KEY=unsafe-dev-key

# Modo debug activo en desarrollo
DEBUG=True

# Acepta cualquier host en desarrollo
ALLOWED_HOSTS=*

# ─── Base de Datos ────────────────────────────────────
DATABASE_URL=sqlite:///db.sqlite3

# ─── CORS ─────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True
