# uv run python -c "from django.utils.crypto import get_random_string; print(get_random_string(50))"
SECRET_KEY=super-secret-production-key

# Siempre False en producción
DEBUG=False

# Dominio(s) permitidos, separados por coma
ALLOWED_HOSTS=your-domain.com

# ─── Base de Datos ────────────────────────────────────
# Formato: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
#
# USER     → usuario de PostgreSQL (POSTGRES_USER en docker-compose.yml)
# PASSWORD → contraseña de PostgreSQL (POSTGRES_PASSWORD en docker-compose.yml)
# HOST     → en Docker usar el nombre del servicio: "db"
#            en local usar: "localhost"
# PORT     → puerto por defecto de PostgreSQL: 5432
# DB_NAME  → nombre de la base de datos (POSTGRES_DB en docker-compose.yml)
#
DATABASE_URL=postgres://app_user:app_password@localhost:5432/app_db